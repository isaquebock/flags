# Root-level ignores for both sub-projects

# Node / TypeScript (function/)
node_modules/
function/dist/
function/build/
function/.env
function/.env.local
function/azion/args.json
npm-debug.log*

# Go (api/)
api/api
api/bin/
api/dist/
api/.env
api/.env.local

# Build artifacts
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Dev runtime (make dev)
.run/
.tools/

# Redis snapshot
dump.rdb

# Console
console/.env.local
console/node_modules/

# Lockfile generated by npm inside function (project uses npm)
function/package-lock.json
