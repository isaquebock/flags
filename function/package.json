{
  "name": "azion-feature-flags-function",
  "version": "0.1.0",
  "description": "Edge Function for feature flags snapshot serving with Azion",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "esbuild src/azion.ts --bundle --minify --platform=neutral --format=esm --outfile=dist/azion.js",
    "build:azion": "npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --max-warnings=0"
  },
  "keywords": [
    "azion",
    "edge-function",
    "feature-flags",
    "hono"
  ],
  "author": "Isaque Bock",
  "license": "MIT",
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.11.0",
    "@types/node": "^20.12.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
